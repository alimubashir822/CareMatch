datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    @default("PATIENT") // SQLite doesn't support custom native enums well in Prisma, using String to ensure safety and flexibility
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  patient       Patient?
  doctor        Doctor?
  clinic        Clinic?
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  auditLogs     AuditLog[]
}

model Patient {
  id                 String       @id @default(uuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth        DateTime?
  gender             String?
  insuranceProvider  String?
  insurancePolicyNum String?
  medicalHistory     String?      // Stored JSON or encrypted string
  
  appointments       Appointment[]
  reviews            Review[]
  documents          Document[]
  waitlists          Waitlist[]
}

model Doctor {
  id                   String       @id @default(uuid())
  userId               String       @unique
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialtyId          String
  specialty            Specialty    @relation(fields: [specialtyId], references: [id])
  clinicId             String?
  clinic               Clinic?      @relation(fields: [clinicId], references: [id])
  
  bio                  String
  experienceYears      Int
  pricePerConsultation Float
  languages            String       // Comma-separated list
  education            String       // JSON-string or rich text
  certifications       String       // JSON-string or rich text
  isApproved           Boolean      @default(false)
  rating               Float        @default(0.0)
  
  availabilities       Availability[]
  appointments         Appointment[]
  reviews              Review[]
  subscriptions        Subscription[]
  documents            Document[]
  waitlists            Waitlist[]
  analytics            Analytics[]
}

model Clinic {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  address     String
  location    String
  rating      Float    @default(0.0)
  
  doctors     Doctor[]
}

model Specialty {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String   // Lucide icon name
  description String
  
  doctors     Doctor[]
}

model Appointment {
  id             String            @id @default(uuid())
  patientId      String
  patient        Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date           DateTime
  timeSlot       String            // e.g., "10:00 AM"
  status         String            @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  type           String            @default("VIDEO")   // VIDEO, IN_PERSON
  serviceName    String            // e.g., "General Consultation"
  price          Float
  notes          String?
  videoRoomId    String?           @default(uuid())
  
  payment        Payment?
  review         Review?
  createdAt      DateTime          @default(now())
}

model Availability {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0-6 (Sunday-Saturday)
  slots     String   // Comma-separated time slots e.g. "09:00 AM,10:00 AM"
}

model Review {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  rating        Int         // 1-5
  comment       String
  reply         String?     // Doctor's response
  createdAt     DateTime    @default(now())
}

model Payment {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Float
  status        String      // e.g., "PAID", "REFUNDED"
  transactionId String      // Mocked or Stripe ID
  invoiceUrl    String?
  createdAt     DateTime    @default(now())
}

model Subscription {
  id             String           @id @default(uuid())
  doctorId       String
  doctor         Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  plan           String           @default("STARTER") // STARTER, PROFESSIONAL, ENTERPRISE
  status         String           // "ACTIVE", "EXPIRED"
  price          Float
  nextBilling    DateTime
  createdAt      DateTime         @default(now())
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String
  attachment  String?
  createdAt   DateTime @default(now())
}

model Document {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  name        String
  url         String
  type        String   // "PRESCRIPTION", "LAB_REPORT", "OTHER"
  uploadedAt  DateTime @default(now())
}

model Waitlist {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  preferredDay Int     // Day of week
  status      String   // "WAITING", "NOTIFIED", "ACCEPTED"
  createdAt   DateTime @default(now())
}

model Analytics {
  id             String   @id @default(uuid())
  doctorId       String
  doctor         Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  profileViews   Int      @default(0)
  bookingsCount  Int      @default(0)
  conversions    Float    @default(0.0) // percentage
  month          String   // e.g., "2026-06"
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  createdAt DateTime @default(now())
}
